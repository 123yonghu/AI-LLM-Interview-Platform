# ========== AI 模拟面试助手 - 环境变量配置 ==========
# 请将此文件复制为 .env 并填入你的真实 API Key
# 注意: .env 文件已被 .gitignore 忽略，不会被提交到版本控制

# 阿里云 DashScope API Key（通义千问 + 语音识别）
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# DeepSeek API Key（AI 面试评估）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ========== 应用配置（可选） ==========
# Flask 运行端口，默认 5000
FLASK_PORT=5000

# Flask 运行地址，默认 127.0.0.1（仅本机访问）
FLASK_HOST=127.0.0.1

# 是否开启调试模式（生产环境务必设为 false）
FLASK_DEBUG=false

# PDF 上传大小上限（MB），默认 20
MAX_UPLOAD_SIZE_MB=20
